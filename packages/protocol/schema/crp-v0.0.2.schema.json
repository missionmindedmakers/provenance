{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cliproot.com/schema/crp-v0.0.2.schema.json",
  "title": "ClipRoot Protocol (CRP) v0.0.2",
  "description": "Minimal protocol bundle schema for document, clipboard, and reuse-event exchanges. Clips are content-addressed (clipHash) enabling offline verification and decentralized lineage chains. Registries are optional accelerators for discovery, not dependencies.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocolVersion": {
      "const": "0.0.2"
    },
    "bundleType": {
      "type": "string",
      "enum": ["document", "clipboard", "reuse-event", "derivation", "provenance-export"]
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "document": {
      "$ref": "#/$defs/document"
    },
    "agents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/agent"
      },
      "default": []
    },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/sourceRecord"
      },
      "default": []
    },
    "clips": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/clip"
      },
      "default": []
    },
    "activities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/activity"
      },
      "default": []
    },
    "derivationEdges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/derivationEdge"
      },
      "default": []
    },
    "reuseEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reuseEvent"
      },
      "default": []
    },
    "signatures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/signature"
      },
      "default": []
    },
    "registry": {
      "$ref": "#/$defs/registryRef"
    }
  },
  "required": ["protocolVersion", "bundleType", "createdAt"],
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9._:-]+$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "sha256Base64Url": {
      "type": "string",
      "pattern": "^sha256-[A-Za-z0-9_-]{43,}$"
    },
    "document": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "title": {
          "type": "string"
        },
        "canonicalHash": {
          "$ref": "#/$defs/sha256Base64Url"
        }
      },
      "required": ["id"]
    },
    "agent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "agentType": {
          "type": "string",
          "enum": ["person", "organization", "model", "service", "system"]
        },
        "name": {
          "type": "string"
        },
        "uri": {
          "$ref": "#/$defs/uri"
        }
      },
      "required": ["id", "agentType"]
    },
    "sourceRecord": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "sourceType": {
          "type": "string",
          "enum": ["human-authored", "ai-generated", "ai-assisted", "external-quoted", "unknown"]
        },
        "digitalSourceType": {
          "$ref": "#/$defs/uri"
        },
        "title": {
          "type": "string"
        },
        "sourceUri": {
          "$ref": "#/$defs/uri"
        },
        "authorAgentId": {
          "$ref": "#/$defs/id"
        },
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        }
      },
      "required": ["id", "sourceType"]
    },
    "textPositionSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": ["start", "end"]
    },
    "textQuoteSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "exact": {
          "type": "string"
        },
        "prefix": {
          "type": "string"
        },
        "suffix": {
          "type": "string"
        }
      },
      "required": ["exact"]
    },
    "domSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provenanceAttribute": {
          "type": "string"
        },
        "elementId": {
          "type": "string"
        },
        "cssSelector": {
          "type": "string"
        },
        "classPath": {
          "type": "string"
        }
      },
      "minProperties": 1
    },
    "mediaTimeSelector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "startMs": {
          "type": "integer",
          "minimum": 0
        },
        "endMs": {
          "type": "integer",
          "minimum": 0
        },
        "track": {
          "type": "string",
          "enum": ["audio", "video"]
        },
        "transcriptCueId": {
          "type": "string"
        }
      },
      "required": ["startMs", "endMs"]
    },
    "clipRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "A reference to a parent or source clip by its content-addressed hash. Enables offline-verifiable lineage chains without requiring a registry.",
      "properties": {
        "clipHash": {
          "$ref": "#/$defs/sha256Base64Url"
        }
      },
      "required": ["clipHash"]
    },
    "registryRef": {
      "type": "object",
      "additionalProperties": false,
      "description": "Optional declaration of a registry where this bundle is indexed. Registries are accelerators for discovery and citation graphs — the clip remains self-verifiable without them.",
      "properties": {
        "uri": {
          "$ref": "#/$defs/uri"
        },
        "bundleId": {
          "type": "string"
        }
      },
      "required": ["uri"]
    },
    "derivationEdge": {
      "type": "object",
      "additionalProperties": false,
      "description": "An edge in the derivation graph linking a child clip to a parent clip. Replaces the former clip-level derivedFrom array with a top-level graph structure.",
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "childClipHash": {
          "$ref": "#/$defs/sha256Base64Url"
        },
        "parentClipHash": {
          "$ref": "#/$defs/sha256Base64Url"
        },
        "transformationType": {
          "type": "string",
          "enum": [
            "verbatim",
            "quote",
            "summary",
            "paraphrase",
            "translate",
            "combine",
            "edit",
            "ai_generate",
            "unknown"
          ]
        },
        "agentId": {
          "$ref": "#/$defs/id"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        }
      },
      "required": ["id", "childClipHash", "parentClipHash", "transformationType", "createdAt"]
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "description": "A content-addressed unit of provenance. clipHash is the global identity derived from the clip's canonical content (textHash + sourceRefs). id is an optional local alias for intra-bundle cross-referencing.",
      "properties": {
        "clipHash": {
          "$ref": "#/$defs/sha256Base64Url",
          "description": "Content-addressed hash of the canonical clip object. This is the global identity of the clip — verifiable offline without any registry."
        },
        "id": {
          "$ref": "#/$defs/id",
          "description": "Optional local alias for referencing this clip within a bundle (e.g. from activities.generatedClipRefs or reuseEvents.sourceRef)."
        },
        "documentId": {
          "$ref": "#/$defs/id"
        },
        "sourceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "selectors": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "textPosition": {
              "$ref": "#/$defs/textPositionSelector"
            },
            "textQuote": {
              "$ref": "#/$defs/textQuoteSelector"
            },
            "editorPath": {
              "type": "string"
            },
            "dom": {
              "$ref": "#/$defs/domSelector"
            },
            "mediaTime": {
              "$ref": "#/$defs/mediaTimeSelector"
            },
            "parentClipHash": {
              "$ref": "#/$defs/sha256Base64Url"
            }
          },
          "minProperties": 1
        },
        "content": {
          "type": "string",
          "description": "Optional embedded text content of the clip. When present alongside clipHash, the clip is fully self-contained and verifiable without the source document."
        },
        "textHash": {
          "$ref": "#/$defs/sha256Base64Url"
        },
        "createdByActivityId": {
          "$ref": "#/$defs/id"
        }
      },
      "required": ["clipHash", "sourceRefs", "textHash"]
    },
    "activity": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "activityType": {
          "type": "string",
          "enum": [
            "create",
            "paste",
            "import",
            "edit",
            "ai_generate",
            "reuse_detected",
            "reuse_notified",
            "copy",
            "derive"
          ]
        },
        "agentId": {
          "$ref": "#/$defs/id"
        },
        "usedSourceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "generatedClipRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        }
      },
      "required": ["id", "activityType", "createdAt"]
    },
    "reuseEvent": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "type": "string",
          "enum": ["detected", "notified", "acknowledged", "rejected"]
        },
        "sourceDocumentId": {
          "$ref": "#/$defs/id"
        },
        "destinationDocumentId": {
          "$ref": "#/$defs/id"
        },
        "sourceRef": {
          "$ref": "#/$defs/id"
        },
        "detectedByActivityId": {
          "$ref": "#/$defs/id"
        },
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        },
        "updatedAt": {
          "$ref": "#/$defs/dateTime"
        }
      },
      "required": ["id", "status", "sourceRef", "createdAt"]
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "alg": {
          "type": "string",
          "enum": ["Ed25519", "ES256", "RS256"]
        },
        "kid": {
          "type": "string"
        },
        "jws": {
          "type": "string"
        },
        "createdAt": {
          "$ref": "#/$defs/dateTime"
        }
      },
      "required": ["id", "alg", "jws"]
    }
  }
}
