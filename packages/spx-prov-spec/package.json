{
  "name": "@provenance/spx-prov-spec",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "sync:assets": "node scripts/sync-assets.mjs",
    "check:assets": "node scripts/sync-assets.mjs --check",
    "build": "rm -rf dist && pnpm run sync:assets && tsc -p tsconfig.json",
    "pretest": "pnpm run sync:assets",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
