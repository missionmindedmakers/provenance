{
  "name": "@cliproot/registry",
  "version": "0.0.1",
  "description": "CRP Registry Server — reference implementation of the CRP Registry Protocol.",
  "license": "Apache-2.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@cliproot/protocol": "workspace:*",
    "@hono/node-server": "^1.13.8",
    "@noble/hashes": "1.8.0",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.36.4",
    "fzstd": "^0.1.1",
    "hono": "^4.7.6",
    "tar-stream": "^3.1.7"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/tar-stream": "^3.1.3",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.3",
    "typescript": "5.7.3",
    "vitest": "3.0.5"
  }
}
