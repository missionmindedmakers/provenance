{
  "name": "cliproot-public-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"schema/**/*.json\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,js,jsx,json,md}\" \"schema/**/*.json\"",
    "changeset": "pnpm dlx @changesets/cli@2.29.6 changeset",
    "version-packages": "pnpm dlx @changesets/cli@2.29.6 version",
    "release": "pnpm dlx @changesets/cli@2.29.6 publish"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "turbo": "2.4.2",
    "typescript": "5.7.3"
  }
}